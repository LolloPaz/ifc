    "from scipy.stats import chi2_contingency\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from sklearn.feature_selection import mutual_info_classif\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "\n",
    "# --- Sector name mapping ---\n",
    "ateco_map = {\n",
    "    (10, 33): \"Manufacturing\", (41, 43): \"Construction\",\n",
    "    (45, 47): \"Wholesale & Retail\", (55, 56): \"Accommodation & Food\",\n",
    "    (58, 63): \"Information & Communication\", (68, 68): \"Real Estate\",\n",
    "    (69, 75): \"Professional & Scientific\", (77, 82): \"Admin & Support\"\n",
    "}\n",
    "\n",
    "def get_sector_name(code):\n",
    "    code_int = int(code)\n",
    "    for (lo, hi), name in ateco_map.items():\n",
    "        if lo <= code_int <= hi:\n",
    "            return name\n",
    "    return \"Other\"\n",
    "\n",
    "train_df[\"sector_name\"] = train_df[\"ateco_sector\"].astype(str).str.zfill(2).apply(get_sector_name)\n",
    "\n",
    "# --- Stats ---\n",
    "contingency = pd.crosstab(train_df[\"sector_name\"], train_df[TARGET])\n",
    "chi2_val, p_val, dof, _ = chi2_contingency(contingency)\n",
    "\n",
    "cross = pd.crosstab(train_df[\"sector_name\"], train_df[TARGET], normalize=\"index\") * 100\n",
    "cross = cross[CLASSES].round(1)\n",
    "\n",
    "X_enc = LabelEncoder().fit_transform(train_df[\"sector_name\"])\n",
    "y_enc = LabelEncoder().fit_transform(train_df[TARGET])\n",
    "mi = mutual_info_classif(X_enc.reshape(-1, 1), y_enc, discrete_features=True)[0]\n",
    "\n",
    "print(f\"Chi²={chi2_val:.2f}, p={p_val:.2e}, dof={dof}\")\n",
    "print(f\"Mutual Info={mi:.4f}\")\n",
    "print(f\"\\nClass % by sector:\\n{cross.sort_values('D', ascending=False)}\")\n",
    "\n",
    "# --- Visual: heatmap + D% bar in one figure ---\n",
    "sector_order = cross[\"D\"].sort_values(ascending=False).index.tolist()\n",
    "cross_sorted = cross.loc[sector_order]\n",
    "\n",
    "fig = make_subplots(\n",
    "    rows=1, cols=2,\n",
    "    column_widths=[0.45, 0.55],\n",
    "    subplot_titles=[\n",
    "        \"Class D % by Sector\",\n",
    "        \"Full Class Distribution Heatmap (%)\"\n",
    "    ]\n",
    ")\n",
    "\n",
    "# Left: horizontal bar — D% only\n",
    "fig.add_trace(go.Bar(\n",
    "    x=cross_sorted[\"D\"].tolist(),\n",
    "    y=cross_sorted.index.tolist(),\n",
    "    orientation=\"h\",\n",
    "    marker_color=\"#d32f2f\",\n",
    "    text=[f\"{v:.1f}%\" for v in cross_sorted[\"D\"]],\n",
    "    textposition=\"outside\",\n",
    "    showlegend=False\n",
    "), row=1, col=1)\n",
    "\n",
    "# Reference line: global D%\n",
    "global_d = train_df[TARGET].value_counts(normalize=True)[\"D\"] * 100\n",
    "fig.add_vline(x=global_d, line_dash=\"dash\", line_color=\"gray\",\n",
    "              annotation_text=f\"Global D: {global_d:.1f}%\",\n",
    "              annotation_position=\"top right\", row=1, col=1)\n",
    "\n",
    "fig.update_xaxes(title_text=\"Class D (%)\", row=1, col=1)\n",
    "fig.update_yaxes(title_text=\"Sector\", row=1, col=1)\n",
    "\n",
    "# Right: heatmap\n",
    "fig.add_trace(go.Heatmap(\n",
    "    z=cross_sorted[CLASSES].values,\n",
    "    x=CLASSES,\n",
    "    y=cross_sorted.index.tolist(),\n",
    "    colorscale=\"RdYlGn_r\",\n",
    "    text=cross_sorted[CLASSES].values,\n",
    "    texttemplate=\"%{text:.1f}%\",\n",
    "    textfont=dict(size=11),\n",
    "    showscale=True,\n",
    "    colorbar=dict(title=\"%\", len=0.8)\n",
    "), row=1, col=2)\n",
    "\n",
    "fig.update_xaxes(title_text=\"Health Class\", row=1, col=2)\n",
    "\n",
    "fig.update_layout(\n",
    "    title={\"text\": (\n",
    "        \"ATECO Sector — Discriminative Power Analysis\"\n",
    "        f\"<br><span style='font-size:15px;font-weight:normal;'>\"\n",
    "        f\"χ²={chi2_val:.1f}, p={p_val:.2e} | Mutual Info={mi:.4f} (moderate standalone power)</span>\"\n",
    "    )},\n",
    "    legend=dict(orientation=\"h\", yanchor=\"bottom\", y=-0.15, xanchor=\"center\", x=0.5),\n",
    ")\n",
    "\n",
    "fig.show()\n"
   ]
  },
