    "# Check for year gaps within a company's history (e.g. 2018, 2020 — missing 2019)\n",
    "def find_gaps(years):\n",
    "    years = sorted(years)\n",
    "    gaps = []\n",
    "    for i in range(len(years) - 1):\n",
    "        expected = years[i] + 1\n",
    "        actual = years[i + 1]\n",
    "        if actual != expected:\n",
    "            gaps.append((years[i], actual))  # (last seen, next seen)\n",
    "    return gaps\n",
    "\n",
